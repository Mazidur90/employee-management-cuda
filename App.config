<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <connectionStrings>
    <add name="EmployeeDbConnectionString" connectionString="Server=your-aws-rds-endpoint;Database=EmployeeDB;User Id=your-user;Password=your-password;MultipleActiveResultSets=true;" providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="AWSRegion" value="us-east-1" />
    <add key="AWSAccessKey" value="your-access-key" />
    <add key="AWSSecretKey" value="your-secret-key" />
    <add key="HRApiUrl" value="https://your-hr-api.com/api" />
    <add key="HRApiKey" value="your-hr-api-key" />
  </appSettings>
</configuration>
